# ─── API Keys ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── LLM Config ──────────────────────────────────────────────────────────────
LLM_MODEL=gpt-4o                     # gpt-4o | gpt-4-turbo | gpt-3.5-turbo
LLM_MAX_TOKENS=1000

# ─── STT Config ──────────────────────────────────────────────────────────────
WHISPER_MODEL=whisper-1              # whisper-1 (cloud) | base | small | medium (local)
USE_LOCAL_WHISPER=false              # true = use local Whisper model (no API cost)

# ─── TTS Config ──────────────────────────────────────────────────────────────
TTS_PROVIDER=openai                  # openai | gtts | elevenlabs

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./voice_agent.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/voice_agent

# ─── Redis (Optional but recommended for production) ─────────────────────────
USE_REDIS=false
REDIS_URL=redis://localhost:6379
SESSION_TTL_SECONDS=3600             # 1 hour session memory TTL
PERSISTENT_TTL_SECONDS=2592000       # 30 day patient context TTL

# ─── Twilio (Optional — for real outbound calls) ─────────────────────────────
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ─── Internal Service URL ────────────────────────────────────────────────────
INTERNAL_API_URL=http://localhost:8000
BACKEND_WEBSOCKET_URL=wss://your-domain.com
